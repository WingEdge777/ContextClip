{
  "name": "context-clip",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "build": "vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "bundle:ext": "bun run build && cd dist && zip -r ../contextclip-extension.zip .",
    "bundle:ext:firefox": "bun run build:firefox && cd dist && zip -r ../contextclip-firefox.zip .",
    "test:golden": "tsx scripts/golden-test.ts",
    "test:golden:update": "tsx scripts/golden-test.ts --update",
    "test:golden:accept": "tsx scripts/golden-test.ts --update --force"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "jsdom": "^27.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  }
}
